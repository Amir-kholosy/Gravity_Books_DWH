      <MdxScripts>
        <MdxScript>
          <ID>MdxScript</ID>
          <Name>MdxScript</Name>
          <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
          <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
          <Commands>
            <Command>
              <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;  
CREATE MEMBER CURRENTCUBE.[Measures].Order_Count
 AS COALESCEEMPTY(
    DISTINCTCOUNT([Sales Fact].[Order_ID_DD]),
    0
), 
FORMAT_STRING = "Standard", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Sales Fact'  ;  
CREATE MEMBER CURRENTCUBE.[Measures].AVG_ORDER_VALUE
 AS IIF(
    [Measures].[Order_Count] = 0,
    NULL,
    SUM(
        EXISTING [Customer Dim 1].[Customer_sk].[Customer_sk].MEMBERS,
        [Measures].[Total Sales]
    )
    /
    [Measures].[Order_Count]
), 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Sales Fact'  ;  
CREATE MEMBER CURRENTCUBE.[Measures].AVG_shipping_cost_perOrder
 AS IIF(
    [Measures].[Order Count] = 0,
    NULL,
    [Measures].[Total Shipping Cost] / [Measures].[Order Count]
), 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Sales Fact'  ;  
CREATE MEMBER CURRENTCUBE.[Measures].Shipping_percentage_ofSales
 AS IIF(
    [Measures].[Total Sales] = 0,
    NULL,
    [Measures].[Total Shipping Cost] / [Measures].[Total Sales]
), 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Sales Fact'  ;  
CREATE MEMBER CURRENTCUBE.[Measures].Profit
 AS COALESCEEMPTY([Measures].[Total Sales], 0)
-
COALESCEEMPTY([Measures].[Total Shipping Cost], 0), 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Sales Fact'  ; </Text>
            </Command>
          </Commands>
        </MdxScript>
      </MdxScripts>
    </Cube>
  </Cubes>
